# Renombrar este archivo a .env y completar los valores
# Todos los valores son OPCIONALES; sin ellos, el sistema usa fallbacks gratuitos.

# Google PageSpeed Insights API Key (gratuita)
# Obtener en: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# User-Agent identificable (recomendado para auditorías académicas)
USER_AGENT=EgovAuditBot/1.0 (Seminario1; investigacion-academica)

# Timeout HTTP en segundos
HTTP_TIMEOUT=20
